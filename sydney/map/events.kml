    <Placemark>
      <name>Anastasia</name>
      <description><![CDATA[<b>Anastasia</b><br><i>Theatre</i><br>Fri 24th Apr – Sat 18th Jul<br>Sydney Lyric Theatre, Sydney<br>Check site<br><br>Musical theatre production based on the historical story.<br><br><a href="https://whatson.cityofsydney.nsw.gov.au/events/anastasia">More info / tickets</a>]]></description>
      <styleUrl>#blue-dot.png</styleUrl>
      <Point>
        <coordinates>151.214808,-33.856765,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Vivid Fire Kitchen</name>
      <description><![CDATA[<b>Vivid Fire Kitchen</b><br><i>Food &amp; Drink</i><br>Fri 22nd May – Sat 13th Jun<br>Barangaroo Reserve, Sydney<br>Check site<br><br>Open every night of Vivid Sydney the Vivid Fire Kitchen is a dining hub with open-fire cooking, food vendors + more.<br><br><a href="https://whatson.cityofsydney.nsw.gov.au/events/vivid-fire-kitchen">More info / tickets</a>]]></description>
      <styleUrl>#red-dot.png</styleUrl>
      <Point>
        <coordinates>151.2011648,-33.8584893,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Vivid at Hollywood Quarter</name>
      <description><![CDATA[<b>Vivid at Hollywood Quarter</b><br><i>Festival</i><br>Sat 30th May<br>Hollywood Quarter, Surry Hills<br>Check site<br><br>Vivid is lighting up Hollywood Quarter in Surry Hills with food, music, and after-dark fun on Saturday, May 30 from 4pm until 4am the next morning.<br><br><a href="https://www.timeout.com/sydney/things-to-do/things-to-do-in-sydney-this-week">More info / tickets</a>]]></description>
      <styleUrl>#orange-dot.png</styleUrl>
      <Point>
        <coordinates>151.212781,-33.885877,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Experimental Sculpture in Clay</name>
      <description><![CDATA[<b>Experimental Sculpture in Clay</b><br><i>Arts &amp; Culture</i><br>Sat 18th Apr – Sat 27th Jun<br>National Art School, Darlinghurst<br>Check site<br><br>Hands-on clay-building techniques workshop.<br><br><a href="https://whatson.cityofsydney.nsw.gov.au/events/experimental-sculpture-in-clay">More info / tickets</a>]]></description>
